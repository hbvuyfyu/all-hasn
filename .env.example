# ─────────────────────────────────────────────────────────────
# HASN Digital Services Platform — Environment Variables
# Copy this file to .env and fill in your values.
# On Railway, set these in the "Variables" tab of your service.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string.
# On Railway: add a Postgres service and use the ${{Postgres.DATABASE_URL}} reference.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ───────────────────────────────────────────────────
# A long random string used to sign session cookies.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-secret

# ── App ───────────────────────────────────────────────────────
# Set to "production" on Railway (enables secure cookies, disables dev tools).
NODE_ENV=production

# Port is set automatically by Railway — do NOT change this in Railway.
# PORT=80
